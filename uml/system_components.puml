@startuml
title System Component Diagram
component "Django Project (unicms)" as unicms
database "SQLite (db.sqlite3)" as db
component "Accounts App" as accounts
component "Complaints App" as complaints
artifact "Templates / Static" as assets
component "Email (SMTP)" as smtp
component "Twilio (SMS)" as twilio

unicms -> accounts : includes
unicms -> complaints : includes
accounts -> db : read/write
complaints -> db : read/write
accounts -> assets : render templates
complaints -> assets : render templates
complaints -> smtp : send emails
complaints -> twilio : send sms

note right of twilio
  Twilio is optional — module falls back to logging
end note

@enduml
