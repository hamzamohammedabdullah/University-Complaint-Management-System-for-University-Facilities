@startuml
title Submit Complaint Sequence (with validation and upload errors)
actor Student
participant Browser
participant Server
participant DB
participant MediaStorage

Student -> Browser: Open /complaints/submit/
Browser -> Server: GET /complaints/submit/
Server -> Browser: render SubmitComplaintForm

Student -> Browser: Fill form + attach files
Browser -> Server: POST /complaints/submit/
Server -> Server: form.is_valid()
alt valid
  Server -> DB: save Complaint (generate complaint_id)
  DB --> Server: complaint instance
  loop for each uploaded file
    Server -> MediaStorage: save file
    alt upload succeeds
      MediaStorage --> DB: create ComplaintMedia
    else upload fails
      Server -> Server: log and continue (optional retry)
    end
  end
  Server -> Server: add_audit(Complaint submitted)
  Server -> Browser: redirect to complaint_detail
else invalid form
  Server -> Browser: render form with errors
  Browser -> Student: display validation messages
end

@enduml
